<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Ekko" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#0F8C78</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#C7F1E8</item>
        <item name="colorOnPrimaryContainer">#00382F</item>

        <item name="colorSecondary">#EC6A47</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#FFD8CD</item>
        <item name="colorOnSecondaryContainer">#57200F</item>

        <item name="colorTertiary">#E3A72D</item>
        <item name="colorOnTertiary">#FFFFFF</item>
        <item name="colorTertiaryContainer">#FFE9B8</item>
        <item name="colorOnTertiaryContainer">#4B3400</item>

        <item name="colorSurface">#FFFDFC</item>
        <item name="colorOnSurface">#1B1A18</item>
        <item name="colorSurfaceVariant">#E8EFEC</item>
        <item name="colorOnSurfaceVariant">#5D6662</item>

        <item name="android:colorBackground">#EDF4F1</item>
        <item name="colorOnBackground">#1B1A18</item>

        <item name="colorOutline">#9FB2AB</item>
        <item name="colorOutlineVariant">#D3E1DB</item>

        <item name="colorError">#B42318</item>
        <item name="colorOnError">#FFFFFF</item>
        <item name="colorErrorContainer">#FEE4E2</item>
        <item name="colorOnErrorContainer">#7A271A</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item
            name="android:windowLightStatusBar"
            tools:targetApi="m"
        >true</item>
        <item name="android:navigationBarColor">#00FFFFFF</item>
        <item
            name="android:windowAnimationStyle"
        >@style/Animation.Ekko.Window</item>
    </style>

    <style name="Theme.Ekko" parent="Base.Theme.Ekko" />

    <style name="Theme.Ekko.Splash" parent="Theme.SplashScreen">
        <item
            name="windowSplashScreenAnimatedIcon"
        >@drawable/ic_splash_mark</item>
        <item
            name="windowSplashScreenBackground"
        >@color/ekko_splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.Ekko.Launcher</item>
    </style>

    <style
        name="Theme.Ekko.Onboarding"
        parent="Theme.Material3.Light.NoActionBar"
    >
        <item name="colorPrimary">#0F8C78</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSurface">#FFFDFC</item>
        <item name="colorOnSurface">#1B1A18</item>
        <item name="colorSurfaceVariant">#E8EFEC</item>
        <item name="colorOnSurfaceVariant">#5D6662</item>
        <item name="android:colorBackground">#F4F8F5</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item
            name="android:windowLightStatusBar"
            tools:targetApi="m"
        >true</item>
        <item
            name="android:navigationBarColor"
        >@android:color/transparent</item>
    </style>

    <style name="Theme.Ekko.Launcher" parent="Theme.Ekko.Onboarding" />

    <style name="BottomNavTextActive">
        <item name="android:textSize">9sp</item>
        <item name="android:fontFamily">@font/bricolage_grotesque</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavTextInactive">
        <item name="android:textSize">9sp</item>
        <item name="android:fontFamily">@font/bricolage_grotesque</item>
    </style>

    <style name="Widget.Ekko.BottomNav.ActiveIndicator" parent="">
        <item name="android:width">56dp</item>
        <item name="android:height">30dp</item>
        <item
            name="shapeAppearance"
        >@style/ShapeAppearance.Material3.Corner.Full</item>
        <item name="color">?attr/colorPrimary</item>
    </style>

    <style name="Widget.Ekko.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">46dp</item>
        <item name="android:fontFamily">@font/bricolage_grotesque</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">999dp</item>
        <item name="iconPadding">6dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.Ekko.Button.Secondary" parent="Widget.Material3.Button">
        <item name="android:minHeight">46dp</item>
        <item name="android:fontFamily">@font/bricolage_grotesque</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">999dp</item>
        <item name="iconPadding">6dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">?attr/colorSurfaceVariant</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="elevation">0dp</item>
    </style>

    <style
        name="Widget.Ekko.Button.Outlined"
        parent="Widget.Material3.Button.OutlinedButton"
    >
        <item name="android:minHeight">46dp</item>
        <item name="android:fontFamily">@font/bricolage_grotesque</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">999dp</item>
        <item name="iconPadding">6dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">?attr/colorSurfaceVariant</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="elevation">0dp</item>
    </style>

    <style
        name="Widget.Ekko.Button.Text"
        parent="Widget.Material3.Button.TextButton"
    >
        <item name="android:minHeight">40dp</item>
        <item name="android:fontFamily">@font/bricolage_grotesque</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">999dp</item>
        <item name="iconPadding">6dp</item>
    </style>

    <style
        name="Widget.Ekko.Button.ToggleTheme"
        parent="Widget.Material3.Button.OutlinedButton"
    >
        <item name="android:minHeight">46dp</item>
        <item name="android:fontFamily">@font/bricolage_grotesque</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">999dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">?attr/colorSurfaceVariant</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style
        name="Animation.Ekko.Window"
        parent="@android:style/Animation.Activity"
    >
        <item
            name="android:activityOpenEnterAnimation"
        >@anim/ekko_activity_open_enter</item>
        <item
            name="android:activityOpenExitAnimation"
        >@anim/ekko_activity_open_exit</item>
        <item
            name="android:activityCloseEnterAnimation"
        >@anim/ekko_activity_close_enter</item>
        <item
            name="android:activityCloseExitAnimation"
        >@anim/ekko_activity_close_exit</item>
    </style>
</resources>
