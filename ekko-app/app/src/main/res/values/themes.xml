<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Ekko" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#4E7A6A</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#D8E8E0</item>
        <item name="colorOnPrimaryContainer">#173228</item>

        <item name="colorSecondary">#C9836A</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#F2DDD4</item>
        <item name="colorOnSecondaryContainer">#562B1E</item>

        <item name="colorTertiary">#7E9270</item>
        <item name="colorOnTertiary">#FFFFFF</item>
        <item name="colorTertiaryContainer">#DFE7D9</item>
        <item name="colorOnTertiaryContainer">#24301D</item>

        <item name="colorSurface">#FFFDFC</item>
        <item name="colorOnSurface">#1B1A18</item>
        <item name="colorSurfaceVariant">#EEF1EC</item>
        <item name="colorOnSurfaceVariant">#6E716B</item>

        <item name="android:colorBackground">#EDF1EC</item>
        <item name="colorOnBackground">#1B1A18</item>

        <item name="colorOutline">#B9C3BB</item>
        <item name="colorOutlineVariant">#DCE3DC</item>

        <item name="colorError">#B42318</item>
        <item name="colorOnError">#FFFFFF</item>
        <item name="colorErrorContainer">#FEE4E2</item>
        <item name="colorOnErrorContainer">#7A271A</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item
            name="android:windowLightStatusBar"
            tools:targetApi="m"
        >true</item>
        <item name="android:navigationBarColor">#00FFFFFF</item>
    </style>

    <style name="Theme.Ekko" parent="Base.Theme.Ekko" />

    <style name="BottomNavTextActive">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/bricolage_grotesque</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavTextInactive">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/bricolage_grotesque</item>
    </style>

    <style name="Widget.Ekko.BottomNav.ActiveIndicator" parent="">
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
        <item
            name="shapeAppearance"
        >@style/ShapeAppearance.Material3.Corner.Full</item>
        <item name="color">@color/bottom_nav_indicator</item>
    </style>
</resources>
