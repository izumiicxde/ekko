    <string name="onboarding_header_title">Meet Ekko</string>
    <string
        name="onboarding_header_subtitle"
    >A calmer space for notes, docs, and answers.</string>
    <string name="onboarding_title_1">Build a calmer document workspace</string>
    <string
        name="onboarding_body_1"
    >Bring your PDFs, notes, slides, and study material into one place with a layout designed to feel light instead of cluttered.</string>
    <string name="onboarding_title_2">Ask across your vault</string>
    <string
        name="onboarding_body_2"
    >Ekko turns indexed material into a searchable study layer so you can jump from questions to grounded answers without losing context.</string>
    <string name="onboarding_title_3">Set it up in minutes</string>
    <string
        name="onboarding_body_3"
    >Choose folders, keep private spaces excluded, or let Ekko import your public storage folders in the background.</string>
    <string name="onboarding_title_4">Set up document access</string>
    <string
        name="onboarding_body_4"
    >On supported phones, Ekko can use wider shared storage access to discover public folders automatically. Otherwise it falls back to the folder picker.</string>
    <string name="onboarding_title_4_storage">Allow shared storage access</string>
    <string
        name="onboarding_body_4_storage"
    >Ekko can scan your public folders in the background when you allow shared storage access on supported Android versions.</string>
    <string name="onboarding_title_4_folder">Choose a source folder</string>
    <string
        name="onboarding_body_4_folder"
    >This Android version uses the folder picker, so Ekko will only ask for the folder you choose.</string>
