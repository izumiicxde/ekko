<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="18dp"
    android:paddingBottom="28dp"
>

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="?attr/colorOutline"
    />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_surface_pill"
        android:fontFamily="@font/bricolage_grotesque"
        android:paddingStart="12dp"
        android:paddingTop="7dp"
        android:paddingEnd="12dp"
        android:paddingBottom="7dp"
        android:text="Library controls"
        android:textColor="?attr/colorOnSurface"
        android:textSize="12sp"
        android:textStyle="bold"
    />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/bricolage_grotesque"
        android:text="Choose how the vault should be shown."
        android:textColor="?attr/colorOnSurface"
        android:textSize="24sp"
        android:textStyle="bold"
    />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_soft_panel"
        android:orientation="vertical"
        android:padding="16dp"
    >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bricolage_grotesque"
            android:letterSpacing="0.08"
            android:text="VIEW"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            android:textStyle="bold"
        />

        <RadioGroup
            android:id="@+id/radioGroupView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
        >

            <RadioButton
                android:id="@+id/radioViewGrouped"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:checked="true"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="Grouped by folder"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
            />

            <RadioButton
                android:id="@+id/radioViewList"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="All files in one list"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
            />

            <RadioButton
                android:id="@+id/radioViewFolders"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="Folder explorer"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
            />
        </RadioGroup>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_soft_panel"
        android:orientation="vertical"
        android:padding="16dp"
    >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bricolage_grotesque"
            android:letterSpacing="0.08"
            android:text="SORT"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            android:textStyle="bold"
        />

        <RadioGroup
            android:id="@+id/radioGroupSort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
        >

            <RadioButton
                android:id="@+id/radioSortRecent"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:checked="true"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="Recently indexed"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
            />

            <RadioButton
                android:id="@+id/radioSortName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="Name (A to Z)"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
            />

            <RadioButton
                android:id="@+id/radioSortWordCount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="Word count (longest first)"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
            />

            <RadioButton
                android:id="@+id/radioSortReadTime"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="Read time (longest first)"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
            />
        </RadioGroup>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_soft_panel"
        android:orientation="vertical"
        android:padding="16dp"
    >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bricolage_grotesque"
            android:letterSpacing="0.08"
            android:text="FILE TYPE"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            android:textStyle="bold"
        />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFileType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:chipSpacingHorizontal="8dp"
            app:selectionRequired="false"
            app:singleSelection="true"
        >

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPdf"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="PDF"
            />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDocx"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="DOCX"
            />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPptx"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="PPTX"
            />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTxt"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="TXT"
            />
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
    >

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/bricolage_grotesque"
            android:text="Reset"
            android:textSize="14sp"
            app:cornerRadius="18dp"
        />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/bricolage_grotesque"
            android:text="Apply"
            android:textSize="14sp"
            app:cornerRadius="18dp"
        />
    </LinearLayout>

</LinearLayout>
