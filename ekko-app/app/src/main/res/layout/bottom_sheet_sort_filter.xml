<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="32dp"
>

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="?attr/colorOutlineVariant"
    />

    <!-- Sort section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View as"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:fontFamily="@font/bricolage_grotesque"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:layout_marginBottom="10dp"
    />

    <RadioGroup
        android:id="@+id/radioGroupView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
    >

        <RadioButton
            android:id="@+id/radioViewList"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="All files in one list"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="@font/bricolage_grotesque"
            android:checked="true"
        />

        <RadioButton
            android:id="@+id/radioViewGrouped"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Grouped by folder"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="@font/bricolage_grotesque"
            android:checked="true"
        />

        <RadioButton
            android:id="@+id/radioViewFolders"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Folder explorer"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="@font/bricolage_grotesque"
        />

    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sort by"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:fontFamily="@font/bricolage_grotesque"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"
    />

    <RadioGroup
        android:id="@+id/radioGroupSort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
    >

        <RadioButton
            android:id="@+id/radioSortRecent"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Recently indexed"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="@font/bricolage_grotesque"
            android:checked="true"
        />

        <RadioButton
            android:id="@+id/radioSortName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Name (A to Z)"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="@font/bricolage_grotesque"
        />

        <RadioButton
            android:id="@+id/radioSortWordCount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Word count (longest first)"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="@font/bricolage_grotesque"
        />

        <RadioButton
            android:id="@+id/radioSortReadTime"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Read time (longest first)"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="@font/bricolage_grotesque"
        />

    </RadioGroup>

    <!-- Filter section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter by type"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:fontFamily="@font/bricolage_grotesque"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"
    />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupFileType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="false"
        app:chipSpacingHorizontal="8dp"
    >

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPdf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PDF"
            android:fontFamily="@font/bricolage_grotesque"
            style="@style/Widget.Material3.Chip.Filter"
        />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipDocx"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOCX"
            android:fontFamily="@font/bricolage_grotesque"
            style="@style/Widget.Material3.Chip.Filter"
        />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPptx"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PPTX"
            android:fontFamily="@font/bricolage_grotesque"
            style="@style/Widget.Material3.Chip.Filter"
        />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TXT"
            android:fontFamily="@font/bricolage_grotesque"
            style="@style/Widget.Material3.Chip.Filter"
        />

    </com.google.android.material.chip.ChipGroup>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
    >

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Reset"
            android:textSize="14sp"
            android:fontFamily="@font/bricolage_grotesque"
            app:cornerRadius="12dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
        />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Apply"
            android:textSize="14sp"
            android:fontFamily="@font/bricolage_grotesque"
            app:cornerRadius="12dp"
        />

    </LinearLayout>

</LinearLayout>
