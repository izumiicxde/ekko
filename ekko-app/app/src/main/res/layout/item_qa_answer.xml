<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="12dp"
>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ekko"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:fontFamily="@font/bricolage_grotesque"
        android:layout_marginBottom="6dp"
    />

    <!--
        Do NOT set fontFamily here. Markwon applies its own typeface spans
        for bold, italic, code etc. A custom fontFamily overrides those spans
        and breaks markdown rendering entirely.
    -->
    <TextView
        android:id="@+id/txtAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurface"
        android:lineSpacingMultiplier="1.4"
        android:lineSpacingExtra="2dp"
    />

    <TextView
        android:id="@+id/txtSource"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="10sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:fontFamily="@font/bricolage_grotesque"
        android:visibility="gone"
    />

</LinearLayout>
