<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/graphRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp"
>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
    >

        <ImageButton
            android:id="@+id/btnGraphBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_surface_pill"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_forward_small"
            android:rotation="180"
            app:tint="?attr/colorOnSurface"
        />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical"
        >

            <TextView
                android:id="@+id/txtGraphTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="Knowledge Map"
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp"
                android:textStyle="bold"
            />

            <TextView
                android:id="@+id/txtGraphSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:visibility="gone"
            />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGraphScope"
            style="@style/Widget.Ekko.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:text="All clusters"
            android:textAllCaps="false"
            android:visibility="gone"
        />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="@drawable/bg_quick_action_card"
        android:padding="14dp"
    >

        <com.semantic.ekko.ui.graph.ClusterGraphView
            android:id="@+id/graphView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
        />

        <ProgressBar
            android:id="@+id/progressGraph"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
        />

        <LinearLayout
            android:id="@+id/layoutGraphEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone"
        >

            <ImageView
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:background="@drawable/bg_icon_pill"
                android:padding="16dp"
                android:src="@drawable/ic_cluster_graph"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="Knowledge map"
            />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="Nothing to map yet"
                android:textColor="?attr/colorOnSurface"
                android:textSize="20sp"
                android:textStyle="bold"
            />

            <TextView
                android:id="@+id/txtGraphEmptyMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:gravity="center"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
            />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
