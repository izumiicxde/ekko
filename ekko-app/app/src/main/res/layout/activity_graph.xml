<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/graphRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:orientation="vertical"
>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
    >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
        >

            <ImageButton
                android:id="@+id/btnGraphBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_surface_pill"
                android:contentDescription="Back"
                android:padding="10dp"
                android:rotation="180"
                android:src="@drawable/ic_arrow_forward_small"
                app:tint="?attr/colorOnSurface"
            />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical"
            >

                <TextView
                    android:id="@+id/txtGraphTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Knowledge Map"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:id="@+id/txtGraphSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:visibility="gone"
                />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGraphScope"
                style="@style/Widget.Ekko.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:textAllCaps="false"
                android:visibility="gone"
            />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_surface_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp"
        >

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGraphModeCluster"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:checkable="true"
                android:checked="true"
                android:minWidth="0dp"
                android:text="Clusters"
                android:textAllCaps="false"
            />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGraphModeFolder"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:checkable="true"
                android:minWidth="0dp"
                android:text="Folders"
                android:textAllCaps="false"
            />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
    >

        <com.semantic.ekko.ui.graph.ClusterGraphView
            android:id="@+id/graphView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
        />

        <ProgressBar
            android:id="@+id/progressGraph"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
        />

        <LinearLayout
            android:id="@+id/layoutGraphEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone"
        >

            <ImageView
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:contentDescription="Knowledge map"
                android:src="@drawable/ic_cluster_graph"
                app:tint="?attr/colorOnSurface"
            />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:text="Nothing to map yet"
                android:textColor="?attr/colorOnSurface"
                android:textSize="20sp"
                android:textStyle="bold"
            />

            <TextView
                android:id="@+id/txtGraphEmptyMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:gravity="center"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
            />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
