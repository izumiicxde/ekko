<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/launcherRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_launcher_screen">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-36dp"
        android:layout_marginEnd="-48dp"
        android:background="@drawable/bg_launcher_orb_primary" />

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-42dp"
        android:layout_marginBottom="72dp"
        android:background="@drawable/bg_launcher_orb_secondary" />

    <LinearLayout
        android:id="@+id/layoutLauncherContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <FrameLayout
            android:id="@+id/launcherMarkWrap"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:background="@drawable/bg_launcher_mark_wrap">

            <ImageView
                android:id="@+id/imgLauncherMark"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_launcher_foreground_circle" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtLauncherTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/bricolage_grotesque"
            android:text="@string/launcher_title"
            android:textColor="?attr/colorOnSurface"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtLauncherSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/bricolage_grotesque"
            android:gravity="center"
            android:text="@string/launcher_subtitle"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtLauncherCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/bricolage_grotesque"
            android:letterSpacing="0.12"
            android:text="@string/launcher_caption"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
