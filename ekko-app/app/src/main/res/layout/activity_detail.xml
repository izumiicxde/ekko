<?xml version="1.0" encoding="utf-8" ?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:colorBackground"
>

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/android:colorBackground"
        app:elevation="0dp"
    >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
        >

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:contentDescription="Back"
                app:tint="?attr/colorOnSurface"
            />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
    >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp"
        >

            <!-- Doc name -->
            <TextView
                android:id="@+id/txtDocName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="@font/bricolage_grotesque"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp"
                tools:text="Introduction to Machine Learning.pdf"
            />

            <!-- Category + file type row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
            >

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:fontFamily="@font/bricolage_grotesque"
                    style="@style/Widget.Material3.Chip.Assist"
                    tools:text="Technical"
                />

                <TextView
                    android:id="@+id/txtFileType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textSize="11sp"
                    android:textColor="?attr/colorPrimary"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:textStyle="bold"
                    android:background="@drawable/bg_file_type_pill"
                    tools:text="PDF"
                />

            </LinearLayout>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_stats_row"
                android:padding="14dp"
            >

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                >

                    <TextView
                        android:id="@+id/txtWordCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textStyle="bold"
                        tools:text="22.4k"
                    />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="words"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:layout_marginTop="2dp"
                    />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="?attr/colorOutlineVariant"
                />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                >

                    <TextView
                        android:id="@+id/txtReadTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textStyle="bold"
                        tools:text="112"
                    />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="min read"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:layout_marginTop="2dp"
                    />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="?attr/colorOutlineVariant"
                />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                >

                    <TextView
                        android:id="@+id/txtEntityCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textStyle="bold"
                        tools:text="5"
                    />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="entities"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:layout_marginTop="2dp"
                    />

                </LinearLayout>

            </LinearLayout>

            <!-- Open file button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenFile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Open File"
                android:textSize="15sp"
                android:fontFamily="@font/bricolage_grotesque"
                app:cornerRadius="12dp"
            />

            <!-- Summary section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Summary"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="@font/bricolage_grotesque"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
            />

            <TextView
                android:id="@+id/txtSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="@font/bricolage_grotesque"
                android:lineSpacingMultiplier="1.7"
                tools:text="This document introduces core machine learning concepts."
            />

            <!-- Keywords section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keywords"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="@font/bricolage_grotesque"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
            />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupKeywords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="4dp"
                app:chipSpacingVertical="4dp"
            />

            <!-- Entities section -->
            <TextView
                android:id="@+id/labelEntities"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entities"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="@font/bricolage_grotesque"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
            />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupEntities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="4dp"
                app:chipSpacingVertical="4dp"
            />

            <!-- Correct category section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correct category"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="@font/bricolage_grotesque"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
            />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCorrection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="4dp"
                app:chipSpacingVertical="4dp"
            >

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCorTechnical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Technical"
                    android:fontFamily="@font/bricolage_grotesque"
                    style="@style/Widget.Material3.Chip.Filter"
                />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCorResearch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Research"
                    android:fontFamily="@font/bricolage_grotesque"
                    style="@style/Widget.Material3.Chip.Filter"
                />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCorLegal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Legal"
                    android:fontFamily="@font/bricolage_grotesque"
                    style="@style/Widget.Material3.Chip.Filter"
                />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCorMedical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medical"
                    android:fontFamily="@font/bricolage_grotesque"
                    style="@style/Widget.Material3.Chip.Filter"
                />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCorGeneral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="General"
                    android:fontFamily="@font/bricolage_grotesque"
                    style="@style/Widget.Material3.Chip.Filter"
                />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
