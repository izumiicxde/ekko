<?xml version="1.0" encoding="utf-8" ?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
    >

        <TextView
            android:id="@+id/txtOnboardingStep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bricolage_grotesque"
            android:letterSpacing="0.08"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
        />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="18dp"
        >

            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_onboarding_hero"
            >

                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_onboarding_icon_orb"
                >

                    <ImageView
                        android:id="@+id/imgOnboardingIcon"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        app:tint="?attr/colorOnPrimary"
                    />
                </FrameLayout>
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/txtOnboardingTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/bricolage_grotesque"
            android:lineSpacingExtra="2dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            android:textStyle="bold"
        />

        <TextView
            android:id="@+id/txtOnboardingBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/bricolage_grotesque"
            android:lineSpacingExtra="2dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
        />

        <TextView
            android:id="@+id/txtOnboardingHighlight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/bricolage_grotesque"
            android:textColor="?attr/colorPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
        />

        <TextView
            android:id="@+id/txtOnboardingTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/bricolage_grotesque"
            android:lineSpacingExtra="2dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="13sp"
        />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
