<?xml version="1.0" encoding="utf-8" ?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
    >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
        >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="@font/bricolage_grotesque"
            />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Your documents, claims, and assistance in one place"
                android:textSize="24sp"
                android:lineSpacingExtra="2dp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="@font/bricolage_grotesque"
                android:textStyle="bold"
            />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Need help with a claim right now?"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/bricolage_grotesque"
                    />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Wise Bot walks you through claims and answers questions from your indexed files."
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:fontFamily="@font/bricolage_grotesque"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHeroWiseBot"
                        android:layout_width="wrap_content"
                        android:layout_height="46dp"
                        android:layout_marginTop="12dp"
                        android:text="Open Wise Bot"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:fontFamily="@font/bricolage_grotesque"
                        app:icon="@drawable/ic_chat"
                        app:iconTint="?attr/colorOnPrimary"
                        app:iconPadding="8dp"
                        app:backgroundTint="?attr/colorPrimary"
                        app:cornerRadius="12dp"
                        android:textColor="?attr/colorOnPrimary"
                    />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutIndexingProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:padding="14dp"
                android:background="@drawable/bg_quick_action_card"
                android:visibility="gone"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                >

                    <TextView
                        android:id="@+id/txtIndexingStage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textStyle="bold"
                        tools:text="Indexing..."
                    />

                    <TextView
                        android:id="@+id/txtIndexingDoc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:fontFamily="@font/bricolage_grotesque"
                        tools:text="2 / 10"
                    />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressIndexing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="false"
                    app:trackCornerRadius="6dp"
                />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/scrollFilterChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingTop="10dp"
                android:paddingBottom="2dp"
            >

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="false"
                />
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
            >

                <TextView
                    android:id="@+id/txtDocCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/bricolage_grotesque"
                    tools:text="4 uploads"
                />

                <ImageButton
                    android:id="@+id/btnSortFilter"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_sort"
                    android:contentDescription="Sort and filter"
                    app:tint="?attr/colorOnSurfaceVariant"
                />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerDocuments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="16dp"
                tools:listitem="@layout/item_document"
            />

            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="56dp"
                android:paddingBottom="36dp"
                android:visibility="gone"
            >

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_folder_open"
                    android:alpha="0.35"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="No uploads"
                />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="No uploads yet"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/bricolage_grotesque"
                />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Upload a policy to get started with AI summaries and Wise Bot."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:fontFamily="@font/bricolage_grotesque"
                />
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
