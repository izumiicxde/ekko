<?xml version="1.0" encoding="utf-8" ?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="28dp"
    >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="16dp"
            android:paddingEnd="14dp"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
            >

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Ekko"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Your calm study space"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="30sp"
                        android:textStyle="bold"
                    />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_icon_pill"
                >

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="Workspace"
                        android:src="@drawable/ic_library"
                        app:tint="?attr/colorOnSurface"
                    />
                </FrameLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="34dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_hero"
                    android:orientation="vertical"
                    android:padding="20dp"
                >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_surface_pill"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="Today in your vault"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                    />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:lineSpacingExtra="2dp"
                        android:text="Read, ask,\nand stay organized."
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="28sp"
                        android:textStyle="bold"
                    />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:lineSpacingExtra="2dp"
                        android:text="A softer workspace for browsing notes, asking questions, and keeping dense material under control."
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp"
                    />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical"
                    >

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnHeroWiseBot"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Ask Ekko Bot"
                            android:textAllCaps="false"
                            android:textColor="?attr/colorOnPrimary"
                            android:textStyle="bold"
                            app:backgroundTint="?attr/colorPrimary"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_chat"
                            app:iconPadding="8dp"
                            app:iconTint="?attr/colorOnPrimary"
                        />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Jump into answers, summaries, and source documents from one clean entry point."
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"
                        />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutIndexingProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_quick_action_card"
                android:orientation="vertical"
                android:padding="18dp"
                android:visibility="gone"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                >

                    <TextView
                        android:id="@+id/txtIndexingStage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Refreshing your vault..."
                    />

                    <TextView
                        android:id="@+id/txtIndexingDoc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_surface_pill"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp"
                        tools:text="2 / 10"
                    />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressIndexing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:indeterminate="false"
                    app:trackCornerRadius="10dp"
                />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/scrollFilterChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="2dp"
                android:scrollbars="none"
            >

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="false"
                    app:singleSelection="true"
                />
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/layoutFolderNavigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_soft_panel"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone"
            >

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFolderBack"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:minWidth="0dp"
                    android:text="Back"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:cornerRadius="14dp"
                />

                <TextView
                    android:id="@+id/txtFolderPath"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:maxLines="1"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    tools:text="Folders / Semester Notes / Unit 2"
                />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
            >

                <TextView
                    android:id="@+id/txtDocCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="4 uploads in vault"
                />

                <ImageButton
                    android:id="@+id/btnSortFilter"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_surface_pill"
                    android:contentDescription="Sort and filter"
                    android:padding="13dp"
                    android:src="@drawable/ic_sort"
                    app:tint="?attr/colorOnSurface"
                />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerDocuments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="16dp"
                tools:listitem="@layout/item_document"
            />

            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_soft_panel"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="54dp"
                android:paddingEnd="20dp"
                android:paddingBottom="40dp"
                android:visibility="gone"
            >

                <ImageView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:alpha="0.85"
                    android:background="@drawable/bg_icon_pill"
                    android:padding="16dp"
                    android:src="@drawable/ic_folder_open"
                    app:tint="?attr/colorOnSurface"
                    android:contentDescription="No uploads"
                />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="No documents yet"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:id="@+id/txtEmptySubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:gravity="center"
                    android:text="Add source folders in Settings to start building a clean, searchable study library."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                />

                <LinearLayout
                    android:id="@+id/layoutEmptyActions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                >

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmptyAddFolder"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Add folder"
                        android:textAllCaps="false"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_add"
                        app:iconPadding="6dp"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmptyOpenSettings"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Open settings"
                        android:textAllCaps="false"
                        app:cornerRadius="14dp"
                    />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
