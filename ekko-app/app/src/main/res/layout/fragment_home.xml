<?xml version="1.0" encoding="utf-8" ?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="28dp"
    >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="16dp"
            android:paddingEnd="14dp"
        >

            <HorizontalScrollView
                android:id="@+id/scrollFilterChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="10dp"
                android:paddingBottom="2dp"
                android:scrollbars="none"
            >

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="false"
                    app:singleSelection="true"
                />
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="top"
                android:orientation="horizontal"
            >

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                >

                    <TextView
                        android:id="@+id/txtDocCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="Your vault is empty"
                    />

                    <TextView
                        android:id="@+id/txtDocMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        tools:text="Add a folder to start building your library"
                    />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnGraph"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_surface_pill"
                    android:contentDescription="Open knowledge map"
                    android:padding="11dp"
                    android:src="@drawable/ic_cluster_graph"
                    app:tint="?attr/colorOnSurface"
                />

                <ImageButton
                    android:id="@+id/btnSortFilter"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_surface_pill"
                    android:contentDescription="Sort and filter"
                    android:padding="11dp"
                    android:src="@drawable/ic_sort"
                    app:tint="?attr/colorOnSurface"
                />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutFolderNavigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
            >

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFolderBack"
                    style="@style/Widget.Ekko.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:minWidth="0dp"
                    android:text="Up"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_arrow_forward_small"
                    app:iconGravity="textStart"
                    app:iconTint="?attr/colorOnSurfaceVariant"
                />

                <TextView
                    android:id="@+id/txtFolderPath"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:maxLines="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="AI > Notes"
                />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerDocuments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="16dp"
                tools:listitem="@layout/item_document"
            />

            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="54dp"
                android:paddingEnd="20dp"
                android:paddingBottom="40dp"
                android:visibility="gone"
            >

                <ImageView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:alpha="0.85"
                    android:background="@drawable/bg_icon_pill"
                    android:padding="16dp"
                    android:src="@drawable/ic_folder_open"
                    app:tint="?attr/colorOnSurface"
                    android:contentDescription="No uploads"
                />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="No documents yet"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:id="@+id/txtEmptySubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:gravity="center"
                    android:text="Add source folders in Settings to start building a clean, searchable study library."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                />

                <LinearLayout
                    android:id="@+id/layoutEmptyActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="vertical"
                >

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmptyAddFolder"
                        style="@style/Widget.Ekko.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Add folder"
                        app:icon="@drawable/ic_add"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmptyOpenSettings"
                        style="@style/Widget.Ekko.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="Open settings"
                    />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutIndexingProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="22dp"
        android:background="@drawable/bg_indexing_float"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="15dp"
        android:paddingEnd="18dp"
        android:paddingBottom="15dp"
        android:visibility="gone"
    >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
            >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_file_type_pill"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:paddingStart="9dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="4dp"
                    android:text="Indexing"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                />

                <TextView
                    android:id="@+id/txtIndexingDoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="24%"
                />
            </LinearLayout>

            <TextView
                android:id="@+id/txtIndexingStage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:ellipsize="end"
                android:fontFamily="@font/bricolage_grotesque"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="lecture_notes_week_4.pdf"
            />

            <TextView
                android:id="@+id/txtIndexingMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:fontFamily="@font/bricolage_grotesque"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="Embedding semantic chunks"
            />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressIndexing"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="12dp"
                android:indeterminate="false"
                app:indicatorColor="?attr/colorPrimary"
                app:trackColor="?attr/colorOutline"
                app:trackCornerRadius="3dp"
            />

            <TextView
                android:id="@+id/txtIndexingRecent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/bricolage_grotesque"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp"
                tools:text="Indexed so far\nDownloads / ml_notes.pdf\nAI / week4-summary.txt"
            />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
