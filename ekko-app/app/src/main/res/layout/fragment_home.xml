<?xml version="1.0" encoding="utf-8" ?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="28dp"
    >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="16dp"
            android:paddingEnd="14dp"
        >

            <LinearLayout
                android:id="@+id/layoutIndexingProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_quick_action_card"
                android:orientation="vertical"
                android:padding="18dp"
                android:visibility="gone"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                >

                    <TextView
                        android:id="@+id/txtIndexingStage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:maxLines="1"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="lecture_notes_week_4.pdf"
                    />

                    <TextView
                        android:id="@+id/txtIndexingDoc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_surface_pill"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp"
                        tools:text="2 / 10"
                    />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Refreshing your vault"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressIndexing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:indeterminate="false"
                    app:trackCornerRadius="10dp"
                />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/scrollFilterChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="2dp"
                android:scrollbars="none"
            >

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="false"
                    app:singleSelection="true"
                />
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/layoutFolderNavigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
            >

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFolderBack"
                    style="@style/Widget.Ekko.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:minWidth="0dp"
                    android:text="Up"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_arrow_forward_small"
                    app:iconGravity="textStart"
                    app:iconTint="?attr/colorOnSurfaceVariant"
                />

                <TextView
                    android:id="@+id/txtFolderPath"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:maxLines="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="AI > Notes"
                />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
            >

                <TextView
                    android:id="@+id/txtDocCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="4 uploads in vault"
                />

                <ImageButton
                    android:id="@+id/btnSortFilter"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_surface_pill"
                    android:contentDescription="Sort and filter"
                    android:padding="13dp"
                    android:src="@drawable/ic_sort"
                    app:tint="?attr/colorOnSurface"
                />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerDocuments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="16dp"
                tools:listitem="@layout/item_document"
            />

            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="54dp"
                android:paddingEnd="20dp"
                android:paddingBottom="40dp"
                android:visibility="gone"
            >

                <ImageView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:alpha="0.85"
                    android:background="@drawable/bg_icon_pill"
                    android:padding="16dp"
                    android:src="@drawable/ic_folder_open"
                    app:tint="?attr/colorOnSurface"
                    android:contentDescription="No uploads"
                />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="No documents yet"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:id="@+id/txtEmptySubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:gravity="center"
                    android:text="Add source folders in Settings to start building a clean, searchable study library."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                />

                <LinearLayout
                    android:id="@+id/layoutEmptyActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="vertical"
                >

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmptyAddFolder"
                        style="@style/Widget.Ekko.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Add folder"
                        app:icon="@drawable/ic_add"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmptyOpenSettings"
                        style="@style/Widget.Ekko.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="Open settings"
                    />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
