<?xml version="1.0" encoding="utf-8" ?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true"
>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="16dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp"
    >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bricolage_grotesque"
            android:text="Settings"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
        />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="34dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_banner"
                android:orientation="vertical"
                android:padding="20dp"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_surface_pill"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="Control center"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                    />

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_icon_pill"
                    >

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:contentDescription="Settings"
                            android:src="@drawable/ic_settings"
                            app:tint="?attr/colorPrimary"
                        />
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Shape the workspace\naround your notes."
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="28sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Manage source folders, control indexing, and keep the rest of Ekko aligned with the way you work."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                >

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stats_row"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="12dp"
                    >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Library"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp"
                        />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Folders + indexing"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            android:textStyle="bold"
                        />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stats_row"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="12dp"
                    >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Theme"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp"
                        />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="System, light, dark"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            android:textStyle="bold"
                        />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFCFA"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                >

                    <FrameLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_icon_pill"
                    >

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="Folders"
                            android:src="@drawable/ic_folder_open"
                            app:tint="?attr/colorPrimary"
                        />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                    >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Source folders"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="19sp"
                            android:textStyle="bold"
                        />

                        <TextView
                            android:id="@+id/txtFolderHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:lineSpacingExtra="2dp"
                            android:text="Included folders appear across Home, Search, and Ekko Bot. Removing a folder only detaches it from Ekko."
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                        />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtFolderStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_surface_pill"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:text="0 sources"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                >

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddFolder"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Add folder"
                        android:textAllCaps="false"
                        android:textColor="?attr/colorOnPrimary"
                        android:textStyle="bold"
                        app:backgroundTint="?attr/colorPrimary"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_upload"
                        app:iconPadding="8dp"
                        app:iconTint="?attr/colorOnPrimary"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReindexIncluded"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Refresh index"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_refresh"
                        app:iconPadding="8dp"
                        app:iconTint="?attr/colorPrimary"
                        app:strokeColor="?attr/colorOutline"
                    />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetExcluded"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Show hidden folders"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorPrimary"
                    app:icon="@drawable/ic_refresh"
                    app:iconPadding="6dp"
                    app:iconTint="?attr/colorPrimary"
                />

                <LinearLayout
                    android:id="@+id/layoutReindexProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_quick_action_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone"
                >

                    <TextView
                        android:id="@+id/txtReindexStage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Embedding..."
                    />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressReindex"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:indeterminate="false"
                        app:trackCornerRadius="10dp"
                    />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerFolders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_folder_setting"
                />

                <TextView
                    android:id="@+id/txtNoFolders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="No folders added yet."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:visibility="gone"
                />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFCFA"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                >

                    <FrameLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_icon_pill"
                    >

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="Appearance"
                            android:src="@drawable/ic_description"
                            app:tint="?attr/colorPrimary"
                        />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                    >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Appearance"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="19sp"
                            android:textStyle="bold"
                        />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Pick how Ekko should look on this device."
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                        />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_stats_row"
                    android:orientation="vertical"
                    android:padding="14dp"
                >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Display mode"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                    />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:selectionRequired="true"
                        app:singleSelection="true"
                    >

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeSystem"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="System"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                        />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeLight"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Light"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                        />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeDark"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Dark"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                        />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFCFA"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
            >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Assistant"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="19sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Jump into Ekko Bot once your included folders are ready."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettingsWiseBot"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Open Ekko Bot"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorOnPrimary"
                    android:textStyle="bold"
                    app:backgroundTint="?attr/colorPrimary"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_chat"
                    app:iconPadding="8dp"
                    app:iconTint="?attr/colorOnPrimary"
                />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
