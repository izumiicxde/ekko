<?xml version="1.0" encoding="utf-8" ?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/transparent"
>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
    >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:fontFamily="@font/bricolage_grotesque"
        />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Manage data sources, appearance, and assistant"
            android:textSize="24sp"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:fontFamily="@font/bricolage_grotesque"
        />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
            >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data Sources"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/bricolage_grotesque"
                />

                <TextView
                    android:id="@+id/txtFolderHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Use Include toggle to hide folders from Home/Search/Ekko Bot. Use X to remove folder + related indexed files from app DB."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:lineSpacingExtra="2dp"
                />

                <TextView
                    android:id="@+id/txtFolderStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0 sources"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/bricolage_grotesque"
                />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddFolder"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:text="Add Source Folder"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:fontFamily="@font/bricolage_grotesque"
                    app:icon="@drawable/ic_upload"
                    app:iconPadding="8dp"
                    app:iconTint="?attr/colorOnPrimary"
                    app:backgroundTint="?attr/colorPrimary"
                    app:cornerRadius="12dp"
                    android:textColor="?attr/colorOnPrimary"
                />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetExcluded"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:text="Show all hidden folders"
                    android:textAllCaps="false"
                    android:fontFamily="@font/bricolage_grotesque"
                    app:icon="@drawable/ic_refresh"
                    app:iconPadding="8dp"
                    app:iconTint="?attr/colorPrimary"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutline"
                    app:backgroundTint="?attr/colorSurface"
                    app:cornerRadius="12dp"
                    android:textColor="?attr/colorPrimary"
                />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReindexIncluded"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:text="Re-index included folders"
                    android:textAllCaps="false"
                    android:fontFamily="@font/bricolage_grotesque"
                    app:icon="@drawable/ic_refresh"
                    app:iconPadding="8dp"
                    app:iconTint="?attr/colorOnPrimary"
                    app:backgroundTint="?attr/colorPrimary"
                    app:cornerRadius="12dp"
                    android:textColor="?attr/colorOnPrimary"
                />

                <LinearLayout
                    android:id="@+id/layoutReindexProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                >

                    <TextView
                        android:id="@+id/txtReindexStage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:fontFamily="@font/bricolage_grotesque"
                        tools:text="Embedding..."
                    />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressReindex"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:indeterminate="false"
                        app:trackCornerRadius="6dp"
                    />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerFolders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_folder_setting"
                />

                <TextView
                    android:id="@+id/txtNoFolders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="No folders added yet."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:visibility="gone"
                />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
            >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Appearance"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/bricolage_grotesque"
                />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Choose how Ekko should look on your device."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/bricolage_grotesque"
                />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                >

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeSystem"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="System"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:fontFamily="@font/bricolage_grotesque"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeLight"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Light"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:fontFamily="@font/bricolage_grotesque"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeDark"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Dark"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:fontFamily="@font/bricolage_grotesque"
                    />

                </com.google.android.material.button.MaterialButtonToggleGroup>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettingsWiseBot"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:text="Open Ekko Bot"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:fontFamily="@font/bricolage_grotesque"
            app:icon="@drawable/ic_chat"
            app:iconPadding="8dp"
            app:iconTint="?attr/colorOnPrimary"
            app:backgroundTint="?attr/colorPrimary"
            app:cornerRadius="12dp"
            android:textColor="?attr/colorOnPrimary"
        />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
