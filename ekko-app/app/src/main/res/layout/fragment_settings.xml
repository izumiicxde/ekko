<?xml version="1.0" encoding="utf-8" ?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true"
>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="16dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp"
    >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bricolage_grotesque"
            android:text="Settings"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
        />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="34dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_banner"
                android:orientation="vertical"
                android:padding="20dp"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                >

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_pill"
                    >

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="Settings"
                            android:src="@drawable/ic_settings"
                            app:tint="?attr/colorPrimary"
                        />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Workspace setup"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                    />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Tune Ekko to match how you study."
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="30sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:lineSpacingExtra="2dp"
                    android:text="Keep folders organized, choose what gets indexed, and set the look of the app without fighting the interface."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                    >

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_surface_pill"
                        />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Folders, indexing, and visibility controls"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                        />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                    >

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_surface_pill"
                        />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Theme and reading atmosphere for this device"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                        />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                >

                    <FrameLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_icon_pill"
                    >

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="Folders"
                            android:src="@drawable/ic_folder_open"
                            app:tint="?attr/colorPrimary"
                        />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                    >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Source folders"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="19sp"
                            android:textStyle="bold"
                        />

                        <TextView
                            android:id="@+id/txtFolderHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:lineSpacingExtra="2dp"
                            android:text="Included folders appear across Home, Search, and Ekko Bot. Removing a folder only detaches it from Ekko."
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                        />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtFolderStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_surface_pill"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:text="0 sources"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical"
                >

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddFolder"
                        style="@style/Widget.Ekko.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Add folder"
                        app:icon="@drawable/ic_upload"
                        app:iconTint="?attr/colorOnPrimary"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReindexIncluded"
                        style="@style/Widget.Ekko.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Refresh index"
                        app:icon="@drawable/ic_refresh"
                        app:iconTint="?attr/colorOnSurface"
                    />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetExcluded"
                    style="@style/Widget.Ekko.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="Show hidden folders"
                    app:icon="@drawable/ic_refresh"
                    app:iconTint="?attr/colorOnSurface"
                />

                <LinearLayout
                    android:id="@+id/layoutReindexProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_quick_action_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone"
                >

                    <TextView
                        android:id="@+id/txtReindexStage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Embedding..."
                    />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressReindex"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:indeterminate="false"
                        app:trackCornerRadius="10dp"
                    />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerFolders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_folder_setting"
                />

                <TextView
                    android:id="@+id/txtNoFolders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="No folders added yet."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:visibility="gone"
                />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_divider"
        />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
            >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                >

                    <FrameLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_icon_pill"
                    >

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="Appearance"
                            android:src="@drawable/ic_description"
                            app:tint="?attr/colorPrimary"
                        />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                    >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Appearance"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="19sp"
                            android:textStyle="bold"
                        />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/bricolage_grotesque"
                            android:text="Pick how Ekko should look on this device."
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                        />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical"
                    android:paddingTop="2dp"
                >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Display mode"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                    />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        app:selectionRequired="true"
                        app:singleSelection="true"
                    >

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeSystem"
                            style="@style/Widget.Ekko.Button.ToggleTheme"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="System"
                            android:textSize="13sp"
                        />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeLight"
                            style="@style/Widget.Ekko.Button.ToggleTheme"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="Light"
                            android:textSize="13sp"
                        />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeDark"
                            style="@style/Widget.Ekko.Button.ToggleTheme"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="Dark"
                            android:textSize="13sp"
                        />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <TextView
                        android:id="@+id/txtThemeSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        tools:text="System follows your phone setting."
                    />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_divider"
        />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
            >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Assistant"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="19sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Jump into Ekko Bot once your included folders are ready."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettingsWiseBot"
                    style="@style/Widget.Ekko.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:text="Open Ekko Bot"
                    app:icon="@drawable/ic_chat"
                    app:iconTint="?attr/colorOnPrimary"
                />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
