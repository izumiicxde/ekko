<?xml version="1.0" encoding="utf-8" ?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true"
>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp"
    >

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_banner"
                android:orientation="vertical"
                android:padding="20dp"
            >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_surface_pill"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="Control center"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Shape the way Ekko feels."
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="28sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Manage folders, re-index your vault, and tune the app appearance from one place."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
            >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Data sources"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:id="@+id/txtFolderHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:lineSpacingExtra="2dp"
                    android:text="Use Include to control what shows up in Home, Search, and Ekko Bot. Remove deletes the folder from Ekko only."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                />

                <TextView
                    android:id="@+id/txtFolderStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_surface_pill"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:text="0 sources"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddFolder"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="14dp"
                    android:text="Add source folder"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:fontFamily="@font/bricolage_grotesque"
                    app:icon="@drawable/ic_upload"
                    app:iconPadding="8dp"
                    app:iconTint="?attr/colorOnPrimary"
                    app:backgroundTint="?attr/colorPrimary"
                    app:cornerRadius="18dp"
                    android:textColor="?attr/colorOnPrimary"
                />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                >

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetExcluded"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Show hidden"
                        android:textAllCaps="false"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_refresh"
                        app:iconPadding="6dp"
                        app:iconTint="?attr/colorPrimary"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReindexIncluded"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Re-index"
                        android:textAllCaps="false"
                        app:backgroundTint="?attr/colorSecondary"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_refresh"
                        app:iconPadding="6dp"
                        app:iconTint="?attr/colorOnSecondary"
                        android:textColor="?attr/colorOnSecondary"
                    />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutReindexProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_quick_action_card"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone"
                >

                    <TextView
                        android:id="@+id/txtReindexStage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Embedding..."
                    />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressReindex"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:indeterminate="false"
                        app:trackCornerRadius="10dp"
                    />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerFolders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_folder_setting"
                />

                <TextView
                    android:id="@+id/txtNoFolders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="No folders added yet."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:visibility="gone"
                />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
            >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Appearance"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="Choose the mood Ekko should use on your device."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:selectionRequired="true"
                    app:singleSelection="true"
                >

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeSystem"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="System"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeLight"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Light"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                    />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeDark"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:text="Dark"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                    />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettingsWiseBot"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/bricolage_grotesque"
            android:text="Open Ekko Bot"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnPrimary"
            android:textStyle="bold"
            app:backgroundTint="?attr/colorPrimary"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_chat"
            app:iconPadding="8dp"
            app:iconTint="?attr/colorOnPrimary"
        />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
